<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yashvendra Singh</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Fraunces:ital,opsz,wght@1,9..144,300;1,9..144,400;1,9..144,600&display=swap" rel="stylesheet">
<style>
:root{--bg:#05080e;--s1:#08101c;--s2:#0c1625;--card:#0e1828;--border:rgba(255,255,255,.06);--c:#5bd4f5;--v:#8b5cf6;--a:#f59e0b;--g:#10b981;--r:#f43f5e;--t:#c8d8f0;--m:#435878;--m2:#6a84a8;--ff:'Syne',sans-serif;--fm:'DM Mono',monospace;--fs:'Fraunces',serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden}
body{background:var(--bg);color:var(--t);font-family:var(--ff);overflow-x:hidden}
a{text-decoration:none;color:inherit}
button{font-family:var(--ff);border:none;cursor:pointer;background:none}
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:9000;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.72' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.035'/%3E%3C/svg%3E");opacity:.28}

/* LOADER */
#loader{position:fixed;inset:0;z-index:8000;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;transition:opacity .6s .1s ease}
#loader.done{opacity:0;pointer-events:none}
.l-lines{position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 56px,rgba(91,212,245,.015) 56px,rgba(91,212,245,.015) 57px);animation:lsc 3s linear infinite}
@keyframes lsc{from{background-position:0 0}to{background-position:0 -112px}}
.l-inner{text-align:center;position:relative;z-index:1}
.l-sub{font-family:var(--fm);font-size:10px;letter-spacing:.35em;color:var(--m);text-transform:uppercase;margin-bottom:28px}
.l-big{font-size:clamp(52px,9vw,96px);font-weight:800;letter-spacing:-.05em;line-height:1;overflow:hidden;min-height:1.1em}
.l-big .ch{display:inline-block;transform:translateY(110%);opacity:0;animation:chup .45s ease forwards}
@keyframes chup{to{transform:translateY(0);opacity:1}}
.l-bar-o{width:180px;height:1px;background:rgba(91,212,245,.1);margin:24px auto 14px;overflow:hidden}
.l-bar-i{height:100%;width:0;background:var(--c);animation:lb 1.8s cubic-bezier(.4,0,.2,1) forwards}
@keyframes lb{0%{width:0}65%{width:82%}100%{width:100%}}
.l-pct{font-family:var(--fm);font-size:10px;color:var(--m);letter-spacing:.15em}

/* NAV */
#nav{position:fixed;top:0;inset-inline:0;z-index:500;padding:22px 56px;display:flex;justify-content:space-between;align-items:center;transition:all .4s ease}
#nav.solid{padding:13px 56px;background:rgba(5,8,14,.92);backdrop-filter:blur(28px);border-bottom:1px solid var(--border)}
.nav-logo{font-family:var(--fm);font-size:11px;letter-spacing:.3em;color:var(--c);text-transform:uppercase;cursor:pointer}
.nav-logo:hover{animation:glitch .45s steps(2) forwards}
@keyframes glitch{0%,100%{transform:none;text-shadow:none;color:var(--c)}20%{transform:translateX(-3px);text-shadow:2px 0 var(--r);color:var(--r)}40%{transform:translateX(3px);text-shadow:-2px 0 var(--v);color:var(--c)}70%{transform:translateX(-1px)}}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--m);font-weight:600;transition:color .25s;position:relative;overflow:hidden;display:inline-block;padding-bottom:2px}
.nav-links a span{display:block;transition:transform .3s ease}
.nav-links a::after{content:attr(data-label);position:absolute;top:100%;left:0;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--c);transition:transform .3s ease}
.nav-links a:hover span{transform:translateY(-100%)}
.nav-links a:hover::after{transform:translateY(-100%)}
.mbtn{position:relative;padding:10px 24px;border:1px solid rgba(91,212,245,.4);color:var(--c);font-size:10px;letter-spacing:.2em;text-transform:uppercase;font-family:var(--fm);overflow:hidden;transition:color .3s;display:inline-block}
.mbtn-bg{position:absolute;inset:0;background:var(--c);transform:scale(0);border-radius:50%;transition:transform .4s cubic-bezier(.22,1,.36,1),border-radius .4s}
.mbtn:hover .mbtn-bg{transform:scale(3);border-radius:0}
.mbtn:hover{color:var(--bg)}
.mbtn>span{position:relative;z-index:1}

/* HERO */
#hero{min-height:100vh;display:flex;align-items:center;padding:140px 56px 100px;position:relative;overflow:hidden}
.hgrid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(91,212,245,.026) 1px,transparent 1px),linear-gradient(90deg,rgba(91,212,245,.026) 1px,transparent 1px);background-size:48px 48px;animation:ga 9s ease-in-out infinite alternate}
@keyframes ga{from{opacity:.5;background-size:48px 48px}to{opacity:1;background-size:53px 53px}}
.hgrid::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 65% 75% at 25% 50%,transparent 25%,var(--bg) 78%)}
.blob{position:absolute;border-radius:50%;pointer-events:none;filter:blur(100px);mix-blend-mode:screen;animation:bfloat 18s ease-in-out infinite}
.b1{width:550px;height:550px;background:rgba(91,212,245,.055);top:-180px;right:-80px;animation-delay:0s}
.b2{width:380px;height:380px;background:rgba(139,92,246,.045);bottom:-80px;right:8%;animation-delay:-6s}
.b3{width:280px;height:280px;background:rgba(245,158,11,.03);top:35%;left:-70px;animation-delay:-12s}
@keyframes bfloat{0%,100%{transform:translate(0,0) scale(1) rotate(0deg)}33%{transform:translate(28px,-18px) scale(1.07) rotate(4deg)}66%{transform:translate(-18px,26px) scale(.93) rotate(-3deg)}}
.hcont{position:relative;z-index:3;max-width:800px}
.hstat-pill{display:inline-flex;align-items:center;gap:10px;background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.17);padding:6px 14px;margin-bottom:30px;font-family:var(--fm);font-size:9.5px;letter-spacing:.22em;color:rgba(16,185,129,.9);text-transform:uppercase;opacity:0;animation:fup .5s .3s ease forwards}
.ldot{width:6px;height:6px;background:var(--g);border-radius:50%;position:relative}
.ldot::after{content:'';position:absolute;inset:-3px;border-radius:50%;border:1px solid var(--g);animation:lping 2s ease-in-out infinite;opacity:.5}
@keyframes lping{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:0;transform:scale(2)}}
.hname{font-size:clamp(54px,9vw,110px);font-weight:800;line-height:.88;letter-spacing:-.055em;margin-bottom:22px;opacity:0;animation:fup .8s .5s ease forwards}
.hname .r1{display:block;color:rgba(200,216,240,.3)}
.hname .r2{display:block}
.hname .hi{color:var(--c);position:relative}
.hname .hi::after{content:'';position:absolute;bottom:3px;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--c),transparent);transform:scaleX(0);transform-origin:left;animation:dl .55s 1.5s ease forwards}
@keyframes dl{to{transform:scaleX(1)}}
.hsub{font-family:var(--fs);font-style:italic;font-size:clamp(16px,2.2vw,24px);color:var(--m2);margin-bottom:22px;opacity:0;animation:fup .6s .7s ease forwards}
.hdesc{font-size:14.5px;line-height:1.88;color:var(--m);max-width:460px;margin-bottom:46px;opacity:0;animation:fup .6s .85s ease forwards}
.hbtns{display:flex;gap:14px;flex-wrap:wrap;opacity:0;animation:fup .6s 1s ease forwards}
.hside{position:absolute;right:56px;top:50%;transform:translateY(-50%);z-index:3;opacity:0;animation:fup .7s 1.2s ease forwards}
.scard{background:rgba(8,16,28,.9);border:1px solid var(--border);padding:18px 24px;text-align:right;margin-bottom:14px;backdrop-filter:blur(16px);position:relative;overflow:hidden;transition:border-color .3s,transform .3s}
.scard:hover{border-color:rgba(91,212,245,.3);transform:translateX(-5px)}
.scard::before{content:'';position:absolute;top:0;left:-70%;width:55%;height:100%;background:linear-gradient(90deg,transparent,rgba(91,212,245,.04),transparent);animation:shim 4.5s ease-in-out infinite}
.scard:nth-child(2)::before{animation-delay:-1.5s}.scard:nth-child(3)::before{animation-delay:-3s}
@keyframes shim{from{left:-70%}to{left:140%}}
.sn{font-family:var(--fm);font-size:29px;font-weight:800;color:var(--c);display:block;line-height:1}
.sl{font-family:var(--fm);font-size:9px;color:var(--m);letter-spacing:.18em;text-transform:uppercase;margin-top:3px}
@keyframes fup{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

/* SECTIONS */
.sec{padding:96px 56px;position:relative}
.ew{font-family:var(--fm);font-size:9px;letter-spacing:.32em;color:var(--c);text-transform:uppercase;display:flex;align-items:center;gap:12px;margin-bottom:12px}
.ew .n{color:var(--m);margin-right:2px}
.ew::after{content:'';width:26px;height:1px;background:rgba(91,212,245,.3)}
.stitle{font-size:clamp(30px,4.5vw,52px);font-weight:800;letter-spacing:-.04em;line-height:.94}
.stitle em{font-family:var(--fs);font-style:italic;font-weight:400;color:var(--m2)}
.divider{height:1px;margin:0 56px;background:var(--border)}
.rv{opacity:0;transform:translateY(22px);transition:opacity .75s ease,transform .75s ease}
.rv.vis{opacity:1;transform:none}
.rvl{opacity:0;transform:translateX(-22px);transition:opacity .7s ease,transform .7s ease}
.rvl.vis{opacity:1;transform:none}
.rvr{opacity:0;transform:translateX(22px);transition:opacity .7s ease,transform .7s ease}
.rvr.vis{opacity:1;transform:none}

/* PROJ STRIP */
.pstrip-wrap{overflow:hidden;position:relative}
.pstrip{display:flex;gap:0;width:max-content;transition:transform .75s cubic-bezier(.22,1,.36,1)}
.pdots{display:flex;gap:8px;align-items:center}
.pdot{width:6px;height:6px;border-radius:50%;background:var(--border);transition:all .3s;cursor:pointer}
.pdot.on{background:var(--c);width:20px;border-radius:3px}
.pnav-btn{width:42px;height:42px;border:1px solid var(--border);color:var(--m2);font-size:17px;display:flex;align-items:center;justify-content:center;transition:all .25s;font-family:monospace}
.pnav-btn:hover{border-color:var(--c);color:var(--c);background:rgba(91,212,245,.04)}

.pc{background:var(--card);border-right:1px solid var(--border);padding:48px 40px;position:relative;overflow:hidden;cursor:pointer;transition:background .35s;flex-shrink:0}
.pc:last-child{border-right:none}
.pc:hover{background:var(--s2)}
/* Clip-path circle fill on hover */
.pc-fill{position:absolute;inset:0;pointer-events:none;background:linear-gradient(135deg,rgba(91,212,245,.04),transparent);clip-path:circle(0% at 50% 50%);transition:clip-path .55s cubic-bezier(.22,1,.36,1)}
.pc[data-c="v"] .pc-fill{background:linear-gradient(135deg,rgba(139,92,246,.05),transparent)}
.pc[data-c="a"] .pc-fill{background:linear-gradient(135deg,rgba(245,158,11,.05),transparent)}
.pc[data-c="g"] .pc-fill{background:linear-gradient(135deg,rgba(16,185,129,.04),transparent)}
.pc:hover .pc-fill{clip-path:circle(100% at 50% 50%)}
/* Top line wipe */
.pc-tl{position:absolute;top:0;left:0;right:0;height:2px;background:var(--c);transform:scaleX(0);transform-origin:left;transition:transform .5s cubic-bezier(.22,1,.36,1)}
.pc[data-c="v"] .pc-tl{background:var(--v)}.pc[data-c="a"] .pc-tl{background:var(--a)}.pc[data-c="g"] .pc-tl{background:var(--g)}
.pc:hover .pc-tl{transform:scaleX(1)}
.pc-n{font-family:var(--fm);font-size:9px;letter-spacing:.28em;color:var(--m);text-transform:uppercase;margin-bottom:26px}
.pc-ico{width:50px;height:50px;margin-bottom:22px;transition:transform .4s cubic-bezier(.34,1.56,.64,1)}
.pc:hover .pc-ico{transform:scale(1.14) rotate(-4deg)}
.pc-tag{font-family:var(--fm);font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--c);margin-bottom:8px}
.pc[data-c="v"] .pc-tag{color:var(--v)}.pc[data-c="a"] .pc-tag{color:var(--a)}.pc[data-c="g"] .pc-tag{color:var(--g)}
.pc-title{font-size:21px;font-weight:800;letter-spacing:-.025em;margin-bottom:11px;line-height:1.15}
.pc-desc{font-size:13.5px;line-height:1.8;color:var(--m);margin-bottom:22px}
.pchips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:28px}
.pch{font-family:var(--fm);font-size:9px;padding:3px 8px;border:1px solid var(--border);color:var(--m);letter-spacing:.06em;transition:all .25s}
.pc:hover .pch{border-color:rgba(91,212,245,.18);color:var(--m2)}
.pc[data-c="v"]:hover .pch{border-color:rgba(139,92,246,.2)}.pc[data-c="a"]:hover .pch{border-color:rgba(245,158,11,.2)}
.pc-cta{font-family:var(--fm);font-size:9.5px;letter-spacing:.15em;text-transform:uppercase;color:var(--c);display:flex;align-items:center;gap:8px}
.pc[data-c="v"] .pc-cta{color:var(--v)}.pc[data-c="a"] .pc-cta{color:var(--a)}.pc[data-c="g"] .pc-cta{color:var(--g)}
.pc-cta .arr{display:inline-block;transition:transform .3s cubic-bezier(.34,1.56,.64,1);font-size:16px}
.pc:hover .pc-cta .arr{transform:translate(6px,-6px)}
.pc-bdg{position:absolute;top:18px;right:18px;font-family:var(--fm);font-size:8.5px;padding:3px 8px;background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.2);color:var(--a);letter-spacing:.08em}

/* MODAL */
.modal{position:fixed;inset:0;z-index:700;display:flex;align-items:center;justify-content:center;padding:20px;pointer-events:none}
.modal-bg{position:absolute;inset:0;background:rgba(2,5,10,.95);backdrop-filter:blur(24px) saturate(1.5);opacity:0;transition:opacity .35s ease}
.modal-box{position:relative;z-index:1;background:var(--s1);max-width:800px;width:100%;max-height:90vh;display:flex;flex-direction:column;opacity:0;transform:translateY(28px) scale(.97);transition:all .45s cubic-bezier(.22,1,.36,1);overflow:hidden}
.modal.open .modal-bg{opacity:1}
.modal.open .modal-box{opacity:1;transform:none;pointer-events:all}
.modal.open{pointer-events:all}
/* Animated accent line */
.m-accent{height:2px;width:0;transition:width .8s .15s cubic-bezier(.22,1,.36,1)}
.modal.open .m-accent{width:100%}
.modal[data-t="c"] .m-accent{background:linear-gradient(90deg,var(--c),transparent)}
.modal[data-t="v"] .m-accent{background:linear-gradient(90deg,var(--v),transparent)}
.modal[data-t="a"] .m-accent{background:linear-gradient(90deg,var(--a),transparent)}
.modal[data-t="g"] .m-accent{background:linear-gradient(90deg,var(--g),transparent)}
.modal[data-t="r"] .m-accent{background:linear-gradient(90deg,var(--r),var(--v))}
.m-hdr{padding:28px 36px 20px;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:2;background:var(--s1);flex-shrink:0}
.modal[data-t="c"] .m-hdr{background-image:radial-gradient(ellipse 80% 100% at 0% 0%,rgba(91,212,245,.05),transparent 60%);background-color:var(--s1)}
.modal[data-t="v"] .m-hdr{background-image:radial-gradient(ellipse 80% 100% at 0% 0%,rgba(139,92,246,.07),transparent 60%);background-color:var(--s1)}
.modal[data-t="a"] .m-hdr{background-image:radial-gradient(ellipse 80% 100% at 0% 0%,rgba(245,158,11,.06),transparent 60%);background-color:var(--s1)}
.modal[data-t="r"] .m-hdr{background-image:radial-gradient(ellipse 80% 100% at 0% 0%,rgba(244,63,94,.05),transparent 60%);background-color:var(--s1)}
.modal[data-t="g"] .m-hdr{background-image:radial-gradient(ellipse 80% 100% at 0% 0%,rgba(16,185,129,.05),transparent 60%);background-color:var(--s1)}
.m-tag{font-family:var(--fm);font-size:9px;letter-spacing:.25em;text-transform:uppercase;margin-bottom:8px;display:block}
.modal[data-t="c"] .m-tag{color:var(--c)}.modal[data-t="v"] .m-tag,.modal[data-t="r"] .m-tag{color:var(--v)}.modal[data-t="a"] .m-tag{color:var(--a)}.modal[data-t="g"] .m-tag{color:var(--g)}
.m-title{font-size:clamp(19px,3vw,29px);font-weight:800;letter-spacing:-.03em;line-height:1.1}
.m-sub{font-size:13px;color:var(--m2);margin-top:7px;line-height:1.65;font-family:var(--fs);font-style:italic}
.m-close{position:absolute;top:16px;right:16px;width:34px;height:34px;border:1px solid var(--border);color:var(--m);font-size:14px;font-family:monospace;display:flex;align-items:center;justify-content:center;transition:all .25s}
.m-close:hover{border-color:var(--c);color:var(--c);background:rgba(91,212,245,.05);transform:rotate(90deg)}
.m-prog{height:1px;width:0;flex-shrink:0;transition:width .08s linear}
.modal[data-t="c"] .m-prog{background:var(--c)}.modal[data-t="v"] .m-prog,.modal[data-t="r"] .m-prog{background:var(--v)}.modal[data-t="a"] .m-prog{background:var(--a)}.modal[data-t="g"] .m-prog{background:var(--g)}
.m-body{overflow-y:auto;flex:1;padding:28px 36px;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.05) transparent}
.ms{margin-bottom:24px}
.ms h4{font-family:var(--fm);font-size:9px;letter-spacing:.25em;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.ms h4::after{content:'';width:26px;height:1px;background:var(--border)}
.modal[data-t="c"] .ms h4{color:var(--c)}.modal[data-t="v"] .ms h4,.modal[data-t="r"] .ms h4{color:var(--v)}.modal[data-t="a"] .ms h4{color:var(--a)}.modal[data-t="g"] .ms h4{color:var(--g)}
.ms p{font-size:13.5px;line-height:1.85;color:var(--m2)}
.ms ul{list-style:none}
.ms li{font-size:13px;color:var(--m2);padding:7px 0;border-bottom:1px solid rgba(255,255,255,.03);display:flex;gap:10px;line-height:1.6}
.ms li::before{content:'›';flex-shrink:0;font-family:monospace}
.modal[data-t="c"] .ms li::before{color:var(--c)}.modal[data-t="v"] .ms li::before,.modal[data-t="r"] .ms li::before{color:var(--v)}.modal[data-t="a"] .ms li::before{color:var(--a)}.modal[data-t="g"] .ms li::before{color:var(--g)}
.mc{display:flex;flex-wrap:wrap;gap:7px}
.mc span{font-family:var(--fm);font-size:10px;padding:4px 10px;border:1px solid var(--border);color:var(--m2);letter-spacing:.07em;transition:all .2s}
.mc span:hover{color:var(--t);border-color:rgba(91,212,245,.2)}
.ml{display:flex;gap:10px;flex-wrap:wrap}
.ml a{padding:10px 20px;font-family:var(--fm);font-size:10px;letter-spacing:.14em;text-transform:uppercase;border:1px solid var(--border);color:var(--m);transition:all .2s;display:inline-flex;align-items:center;gap:7px}
.ml a:hover{border-color:var(--c);color:var(--c);background:rgba(91,212,245,.03)}
.ml a.mp{background:var(--c);color:var(--bg);border-color:var(--c);font-weight:700}
.ml a.mp:hover{background:transparent;color:var(--c)}
.modal[data-t="v"] .ml a.mp,.modal[data-t="r"] .ml a.mp{background:var(--v);border-color:var(--v);color:#fff}
.modal[data-t="v"] .ml a.mp:hover,.modal[data-t="r"] .ml a.mp:hover{background:transparent;color:var(--v)}
.modal[data-t="a"] .ml a.mp{background:var(--a);border-color:var(--a);color:var(--bg)}
.modal[data-t="a"] .ml a.mp:hover{background:transparent;color:var(--a)}
.arch{display:flex;flex-wrap:wrap;gap:6px;align-items:center;margin-top:10px}
.ab{font-family:var(--fm);font-size:9.5px;padding:6px 11px;background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--t)}
.aa{font-size:11px;color:var(--m)}
.prose{font-family:var(--fs);font-size:17px;line-height:1.92;color:var(--m2)}
.prose p{margin-bottom:18px}
.prose h3{font-family:var(--ff);font-size:14.5px;font-weight:700;color:var(--t);margin:24px 0 10px;letter-spacing:-.01em}
.prose blockquote{margin:20px 0;padding:13px 18px;border-left:2px solid var(--v);font-style:italic;background:rgba(139,92,246,.04);color:var(--m2)}
.bmr{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:22px}
.bm{font-family:var(--fm);font-size:9px;letter-spacing:.14em;color:var(--m);text-transform:uppercase}

/* SKILLS */
.sk-wrap{display:grid;grid-template-columns:repeat(auto-fill,minmax(145px,1fr));gap:8px}
.sk{display:flex;align-items:center;gap:10px;padding:12px 15px;background:var(--s1);border:1px solid var(--border);font-size:12.5px;font-weight:600;color:var(--m2);position:relative;overflow:hidden;transition:all .3s;cursor:default}
