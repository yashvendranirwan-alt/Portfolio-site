<script>
/* LOADER */
const nm='YASHVENDRA',lb=document.getElementById('lbig');
nm.split('').forEach((c,i)=>{const s=document.createElement('span');s.className='ch';s.textContent=c;s.style.animationDelay=(.28+i*.055)+'s';lb.appendChild(s)});
let p=0;const pe=document.getElementById('lpct');
const lt=setInterval(()=>{p=Math.min(p+Math.random()*12+2,98);pe.textContent=Math.floor(p)+'%'},90);
function done(){clearInterval(lt);pe.textContent='100%';setTimeout(()=>{document.getElementById('loader').classList.add('done')},350)}
window.addEventListener('load',()=>setTimeout(done,500));
setTimeout(done,2600);

/* TEXT SCRAMBLE */
const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%';
function scramble(el,final,dur=1000){
  let f=0;const tf=Math.floor(dur/40),rv=Math.ceil(final.length/tf);
  const id=setInterval(()=>{
    let out='';
    for(let i=0;i<final.length;i++){
      if(i<f*rv)out+=final[i];
      else if(final[i]===' ')out+=' ';
      else out+=chars[Math.floor(Math.random()*chars.length)];
    }
    el.textContent=out;f++;
    if(f*rv>=final.length){el.textContent=final;clearInterval(id)}
  },40);
}
setTimeout(()=>{
  const r1=document.getElementById('hr1'),r2=document.getElementById('hr2');
  if(r1)scramble(r1,'Yash',700);
  if(r2)scramble(r2,'vendra',900);
},1600);

/* NAV */
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('solid',scrollY>40));

/* GLITCH logo */
document.getElementById('nlg').addEventListener('mouseenter',function(){this.classList.add('glitch');setTimeout(()=>this.classList.remove('glitch'),500)});

/* SCROLL REVEAL */
const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')}),{threshold:.07,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.rv,.rvl,.rvr').forEach(el=>io.observe(el));

/* SKILL STAGGER */
document.querySelectorAll('.sk').forEach((s,i)=>s.style.transitionDelay=i*.028+'s');

/* NUMBER COUNTER */
function countUp(el,target,dur=1200){
  let s=null;
  const step=ts=>{if(!s)s=ts;const prog=Math.min((ts-s)/dur,1),ease=1-Math.pow(1-prog,3);
    el.textContent=Math.floor(ease*target)+(target===20?'+':'');if(prog<1)requestAnimationFrame(step)};
  requestAnimationFrame(step);
}
const cio=new IntersectionObserver(es=>{
  es.forEach(e=>{if(e.isIntersecting){document.querySelectorAll('.count-up').forEach(el=>countUp(el,+el.dataset.t));cio.disconnect()}})
},{threshold:.3});
const hs=document.querySelector('.hside');if(hs)cio.observe(hs);

/* PROJ HORIZONTAL SCROLL */
let si=0;
const strip=document.getElementById('pstrip');
const dots=document.querySelectorAll('#pdots .pdot');
function gS(i){
  const cards=strip.querySelectorAll('.pc');
  si=Math.max(0,Math.min(i,cards.length-1));
  strip.style.transform=`translateX(-${si*420}px)`;
  dots.forEach((d,idx)=>d.classList.toggle('on',idx===si));
}
function sR(){gS(si+1)}function sL(){gS(si-1)}
/* Touch */
let tx=0;
strip.addEventListener('touchstart',e=>{tx=e.touches[0].clientX},{passive:true});
strip.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx;if(Math.abs(dx)>50)dx<0?sR():sL()});

/* MODAL */
function OM(id){document.getElementById(id).classList.add('open');document.body.style.overflow='hidden'}
function CM(id){document.getElementById(id).classList.remove('open');document.body.style.overflow=''}
document.addEventListener('keydown',e=>{if(e.key==='Escape'){document.querySelectorAll('.modal.open').forEach(m=>m.classList.remove('open'));document.body.style.overflow=''}});
document.querySelectorAll('.m-close').forEach(b=>b.addEventListener('click',function(){CM(this.closest('.modal').id)}));
document.querySelectorAll('.modal').forEach(m=>{
  const body=m.querySelector('.m-body'),prog=m.querySelector('.m-prog');
  if(!body||!prog)return;
  body.addEventListener('scroll',()=>{prog.style.width=Math.min(body.scrollTop/(body.scrollHeight-body.clientHeight)*100||0,100)+'%'});
});

/* MAGNETIC BUTTONS */
document.querySelectorAll('.mbtn').forEach(btn=>{
  btn.addEventListener('mousemove',function(e){
    const r=this.getBoundingClientRect();
    const dx=(e.clientX-r.left-r.width/2)*.28,dy=(e.clientY-r.top-r.height/2)*.28;
    this.style.transform=`translate(${dx}px,${dy}px)`;
  });
  btn.addEventListener('mouseleave',function(){
    this.style.transition='transform .45s cubic-bezier(.22,1,.36,1)';
    this.style.transform='';
    setTimeout(()=>this.style.transition='',450);
  });
  btn.addEventListener('mouseenter',function(){this.style.transition=''});
});
</script>
